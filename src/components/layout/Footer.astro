---
---

<footer class="bg-[#263238] text-white">
  <!-- Impact strip -->
  <div class="border-b border-white/8 bg-[#1e2d34]">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16">
        <div class="text-center">
          <div class="text-3xl font-[Satoshi] font-semibold text-[#FFB300]">9</div>
          <div class="text-xs text-white/40 font-medium tracking-widest uppercase mt-1">Countries</div>
        </div>
        <div class="w-px h-10 bg-white/10 hidden md:block"></div>
        <div class="text-center">
          <div class="text-3xl font-[Satoshi] font-semibold text-[#FFB300]">51,800+</div>
          <div class="text-xs text-white/40 font-medium tracking-widest uppercase mt-1">Children Supported</div>
        </div>
        <div class="w-px h-10 bg-white/10 hidden md:block"></div>
        <div class="text-center">
          <div class="text-3xl font-[Satoshi] font-semibold text-[#FFB300]">$33</div>
          <div class="text-xs text-white/40 font-medium tracking-widest uppercase mt-1">Starting / Month</div>
        </div>
        <div class="w-px h-10 bg-white/10 hidden md:block"></div>
        <div class="text-center">
          <div class="text-3xl font-[Satoshi] font-semibold text-[#FFB300]">100%</div>
          <div class="text-xs text-white/40 font-medium tracking-widest uppercase mt-1">To Orphan Care</div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-14">
      <!-- Brand (wider) -->
      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-5">
          <img src="/logo.jpeg" alt="Orphan Aid" width="132" height="132" class="rounded-xl object-cover" />
        </div>
        <p class="text-white/45 leading-[1.7] text-sm max-w-sm mb-6">
          A registered Canadian charity building a global network of care for
          orphaned children — one sponsor at a time. Every dollar goes where it matters most.
        </p>

        <!-- Email updates -->
        <div class="flex gap-2 max-w-sm">
          <input
            type="email"
            placeholder="Your email address"
            class="flex-1 bg-white/6 border border-white/10 rounded-xl px-4 py-2.5 text-sm text-white placeholder-white/30 focus:outline-none focus:border-[#FFB300]/50 transition-colors"
          />
          <button class="bg-[#FFB300] text-[#263238] px-4 py-2.5 rounded-xl text-sm font-bold hover:bg-[#e6a100] transition-colors shrink-0">
            Subscribe
          </button>
        </div>

        <div class="mt-5 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/8 text-white/35 text-xs font-medium">
          🇨🇦 Registered Canadian Charitable Organization
        </div>
      </div>

      <!-- Spacer -->
      <div class="md:col-span-1"></div>

      <!-- Navigation -->
      <div class="md:col-span-2">
        <h3 class="text-[10px] font-bold tracking-widest uppercase text-white/35 mb-5">Navigation</h3>
        <ul class="space-y-3.5">
          {["Mission", "Our Reach", "Sponsor", "Why Us", "FAQ"].map((link) => (
            <li>
              <a
                href={`#${link.toLowerCase().replace(/\s+/g, "")}`}
                class="text-sm text-white/55 hover:text-white transition-colors duration-200 flex items-center gap-2 group"
              >
                <span class="w-0 group-hover:w-3 h-px bg-[#FFB300] transition-all duration-200 inline-block"></span>
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact & Social -->
      <div class="md:col-span-4">
        <h3 class="text-[10px] font-bold tracking-widest uppercase text-white/35 mb-5">Connect</h3>
        <ul class="space-y-3.5 mb-8">
          <li>
            <a href="mailto:info@orphanaid.ca" class="text-sm text-white/55 hover:text-white transition-colors duration-200 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              info@orphanaid.ca
            </a>
          </li>
          <li>
            <a href="#" class="text-sm text-white/55 hover:text-white transition-colors duration-200 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="#" class="text-sm text-white/55 hover:text-white transition-colors duration-200 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              About Us
            </a>
          </li>
        </ul>

        <!-- Social icons -->
        <div class="flex gap-3">
          {[
            { name: "Twitter/X", path: "M23 3a10.9 10.9 0 0 1-3.14 1.53A4.48 4.48 0 0 0 22.43 2a9.08 9.08 0 0 1-2.89 1.1 4.52 4.52 0 0 0-7.69 4.12 12.82 12.82 0 0 1-9.28-4.7 4.52 4.52 0 0 0 1.4 6.04 4.5 4.5 0 0 1-2.05-.56v.06a4.52 4.52 0 0 0 3.62 4.43 4.52 4.52 0 0 1-2 .08 4.52 4.52 0 0 0 4.22 3.13A9.06 9.06 0 0 1 1 18.41a12.78 12.78 0 0 0 6.92 2.02 12.78 12.78 0 0 0 12.86-12.86l-.02-.59A9.16 9.16 0 0 0 23 3z" },
            { name: "Instagram", path: "M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37zm1.5-4.87h.01M7.5 2h9a5.5 5.5 0 0 1 5.5 5.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2z" },
            { name: "Facebook", path: "M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" },
          ].map((s) => (
            <a
              href="#"
              aria-label={s.name}
              class="w-9 h-9 rounded-xl bg-white/6 border border-white/8 flex items-center justify-center hover:bg-[#FFB300] hover:border-[#FFB300] hover:text-[#263238] transition-all duration-200 text-white/55"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
                <path d={s.path} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/8 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-sm">
        © 2025 Orphan Aid. All rights reserved.
      </p>
      <p class="text-white/20 text-xs text-center sm:text-right">
        Built with care to serve the world's most vulnerable children.
      </p>
    </div>
  </div>
</footer>
