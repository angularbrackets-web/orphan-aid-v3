---
import { FAQAccordion } from "@/components/react/FAQAccordion";
---

<section id="faq" class="relative py-28 md:py-36 bg-white overflow-hidden">
  <div class="relative z-10 max-w-4xl mx-auto px-6">
    <!-- Label -->
    <div class="animate-in-element flex justify-center mb-8">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#0d47a1]/8 border border-[#0d47a1]/15 text-[#0d47a1] text-xs font-[Montserrat] font-semibold tracking-widest uppercase">
        Transparency & Trust
      </span>
    </div>

    <!-- Headline -->
    <div class="animate-in-element text-center mb-16">
      <h2 class="font-[Montserrat] font-semibold text-[#263238] leading-[1.05] tracking-[-0.02em] mb-4" style="font-size: clamp(2.8rem, 6vw, 4.5rem)">
        Committed to<br />
        <span class="relative inline-block">
          Accountability
          <span class="absolute -bottom-2 left-0 right-0 h-1 rounded-full bg-[#FFB300]"></span>
        </span>
      </h2>
      <p class="mt-8 text-lg font-[Inter] text-[#263238]/55 leading-[1.6] max-w-2xl mx-auto">
        We believe trust is built through transparency. Here are answers to the questions we hear most.
      </p>
    </div>

    <!-- Trust badges — no icons, clean text-only -->
    <div class="animate-in-element grid grid-cols-2 sm:grid-cols-4 gap-4 mb-16">
      {[
        { label: "Canadian Charity", value: "Registered", sub: "CRA #123456" },
        { label: "Tax Receipts", value: "Official", sub: "All donations" },
        { label: "Flexibility", value: "Cancel", sub: "Anytime" },
        { label: "Inclusive", value: "All Faiths", sub: "Welcome" },
      ].map((badge, i) => (
        <div class="group h-full">
          <div class="relative h-full flex flex-col p-5 rounded-2xl bg-[#f7f8fa] border border-[#e8ecf0] group-hover:border-[#0d47a1]/25 group-hover:bg-[#f0f4ff] group-hover:-translate-y-0.5 group-hover:shadow-[0_6px_24px_rgba(13,71,161,0.08)] transition-all duration-250 overflow-hidden">
            <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-[#0d47a1] scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-full"></div>
            <span class="text-[9px] font-[Montserrat] font-bold tracking-widest uppercase text-[#263238]/35 mb-1">{badge.label}</span>
            <span class="text-base font-[Montserrat] font-bold text-[#263238] leading-tight">{badge.value}</span>
            <span class="text-[11px] font-[Inter] text-[#263238]/45 mt-0.5">{badge.sub}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Accordion -->
    <div class="animate-in-element">
      <FAQAccordion client:visible />
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('is-visible');
    }),
    { threshold: 0.08, rootMargin: '-40px' }
  );
  document.querySelectorAll('#faq .animate-in-element').forEach(el => observer.observe(el));
</script>
