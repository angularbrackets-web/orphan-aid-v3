---
import { Image } from 'astro:assets';
import { EtheralShadows } from "@/components/react/EtheralShadows";
import { FallingPattern } from "@/components/react/FallingPattern";
import orphan1 from '@/assets/images/orphan-1.jpg';
import orphan2 from '@/assets/images/orphan-2.jpg';
import orphan3 from '@/assets/images/orphan-3.jpg';
---

<section id="mission" class="relative py-28 md:py-36 bg-[#efefef] overflow-hidden">
  <!-- EtheralShadows: grainy blob shadows per reference -->
  <EtheralShadows
    client:visible
    color="rgba(145, 145, 145, 0.9)"
    animation={{ scale: 35, speed: 35 }}
    noise={{ opacity: 1.2, scale: 1.5 }}
    sizing="fill"
    className="absolute inset-0 w-full h-full"
  />

  <!-- Falling pattern overlay (very subtle) -->
  <FallingPattern
    client:visible
    color="rgba(0,0,0,0.035)"
    backgroundColor="transparent"
    duration={180}
    blurIntensity="0.5em"
    density={1.2}
    className="absolute inset-0 w-full h-full z-[1]"
  />

  <div class="relative z-10 max-w-6xl mx-auto px-6">
    <!-- Section label -->
    <div class="animate-in-element flex justify-center mb-8">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#263238]/8 border border-[#263238]/15 text-[#263238]/60 text-xs font-[Montserrat] font-semibold tracking-widest uppercase">
        Our Mission
      </span>
    </div>

    <!-- Headline -->
    <div class="animate-in-element text-center max-w-4xl mx-auto mb-16">
      <h2 class="font-[Montserrat] font-semibold text-[#263238] leading-[1.05] tracking-[-0.02em] mb-8" style="font-size: clamp(2.8rem, 6vw, 4.5rem)">
        Millions of children are growing up<br class="hidden sm:block" />
        <span class="text-[#0d47a1]">without support.</span>
      </h2>
      <p class="text-lg md:text-xl font-[Inter] text-[#263238]/65 leading-[1.6] max-w-3xl mx-auto">
        Orphaned children worldwide are struggling without the stability, care, and essentials they need to thrive.
        Our mission is to build a global network of care that supports these children with
        <strong class="text-[#263238] font-semibold">dignity, consistency, and lasting impact.</strong>
      </p>
    </div>

    <!-- Photo bento grid -->
    <div class="mb-16 grid gap-4" style="grid-template-columns: 1fr 1.3fr; height: 580px">
      <!-- Left: portrait — object-position focuses on the children's faces -->
      <div class="animate-in-element group h-full" style="transition-delay: 100ms">
        <div class="relative h-full rounded-2xl overflow-hidden border border-[#263238]/8 shadow-[0_4px_24px_rgba(0,0,0,0.06)] group-hover:shadow-[0_8px_40px_rgba(0,0,0,0.12)] group-hover:-translate-y-1 transition-all duration-300">
          <Image
            src={orphan2}
            alt="Children at an orphanage"
            width={640}
            height={1209}
            class="absolute inset-0 w-full h-full object-cover"
            style="object-position: center 18%"
            loading="lazy"
            decoding="async"
            format="webp"
          />
        </div>
      </div>
      <!-- Right: landscape top (bigger), portrait bottom (more height for the child) -->
      <div class="grid gap-4" style="grid-template-rows: 1.6fr 2.4fr">
        <div class="animate-in-element group h-full" style="transition-delay: 200ms">
          <div class="relative h-full rounded-2xl overflow-hidden border border-[#263238]/8 shadow-[0_4px_24px_rgba(0,0,0,0.06)] group-hover:shadow-[0_8px_40px_rgba(0,0,0,0.12)] group-hover:-translate-y-1 transition-all duration-300">
            <Image
              src={orphan1}
              alt="A young orphan child"
              width={640}
              height={427}
              class="absolute inset-0 w-full h-full object-cover"
              style="object-position: center 40%"
              loading="lazy"
              decoding="async"
              format="webp"
            />
          </div>
        </div>
        <div class="animate-in-element group h-full" style="transition-delay: 300ms">
          <div class="relative h-full rounded-2xl overflow-hidden border border-[#263238]/8 shadow-[0_4px_24px_rgba(0,0,0,0.06)] group-hover:shadow-[0_8px_40px_rgba(0,0,0,0.12)] group-hover:-translate-y-1 transition-all duration-300">
            <Image
              src={orphan3}
              alt="An orphan child smiling"
              width={640}
              height={960}
              class="absolute inset-0 w-full h-full object-cover"
              style="object-position: center 58%"
              loading="lazy"
              decoding="async"
              format="webp"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Mission statement -->
    <div class="animate-in-element text-center max-w-3xl mx-auto">
      <blockquote class="text-xl md:text-2xl font-[Inter] text-[#263238]/75 font-light italic leading-relaxed border-l-4 border-[#FFB300] pl-6 text-left">
        "We aren't just providing aid — we are building a scalable model focused on
        <em class="not-italic text-[#263238] font-semibold">protection and opportunity</em>
        for the most vulnerable."
      </blockquote>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('is-visible');
    }),
    { threshold: 0.1, rootMargin: '-60px' }
  );
  document.querySelectorAll('#mission .animate-in-element').forEach(el => observer.observe(el));
</script>
