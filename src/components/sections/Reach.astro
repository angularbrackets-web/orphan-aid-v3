---
import { WorldMap } from "@/components/react/WorldMap";
import { orphanAidMarkers, highCrisisCountries, vulnerableCountries } from "@/data/countries";

const canadaHQ = { lat: 56.13, lng: -106.35, label: "Canada" };

const mapDots = orphanAidMarkers.map(country => ({
  start: canadaHQ,
  end: { lat: country.location[0], lng: country.location[1], label: country.label },
  color: country.crisis === "high" ? "#ef4444" : "#56ACE0",
}));
---

<section id="reach" class="relative py-24 md:py-32 bg-[#080d1a] overflow-hidden">

  <!-- Subtle radial glow behind map -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80%] h-[60%] rounded-full bg-[#56ACE0]/4 blur-[120px]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">

    <!-- Label -->
    <div class="animate-in-element flex justify-center mb-8">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/8 border border-white/15 text-white/70 text-xs font-[Montserrat] font-semibold tracking-widest uppercase">
        Global Reach
      </span>
    </div>

    <!-- Headline -->
    <div class="animate-in-element text-center max-w-3xl mx-auto mb-5">
      <h2 class="font-[Montserrat] font-semibold text-white leading-[1.05] tracking-[-0.02em]" style="font-size: clamp(2.8rem, 6vw, 4.5rem)">
        Delivering Support<br />
        <span style="color: #56ACE0">Across Borders</span>
      </h2>
    </div>
    <div class="animate-in-element text-center max-w-2xl mx-auto mb-4">
      <p class="text-lg font-[Inter] text-white/50 leading-[1.6]">
        From our base in Canada, Orphan Aid reaches the world's most critical
        humanitarian zones — delivering care where it matters most.
      </p>
    </div>

    <!-- World Map -->
    <div class="animate-in-element -mx-6 md:mx-0">
      <WorldMap
        client:visible
        dots={mapDots}
        lineColor="#56ACE0"
      />
    </div>

    <!-- Country tags row -->
    <div class="animate-in-element mt-10 flex flex-col sm:flex-row gap-8 justify-center items-start sm:items-center">

      <!-- High-Crisis -->
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse shrink-0"></span>
          <span class="text-[10px] font-[Montserrat] font-bold tracking-widest uppercase text-red-400">High-Crisis Zones</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {highCrisisCountries.map(c => (
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-red-500/10 border border-red-500/20 text-white/80 text-xs font-[Inter] font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-red-400 shrink-0"></span>
              {c.label}
            </span>
          ))}
        </div>
      </div>

      <!-- Divider -->
      <div class="hidden sm:block w-px h-12 bg-white/10 shrink-0"></div>

      <!-- Vulnerable -->
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2 h-2 rounded-full shrink-0" style="background: #56ACE0"></span>
          <span class="text-[10px] font-[Montserrat] font-bold tracking-widest uppercase" style="color: #56ACE0">Vulnerable Communities</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {vulnerableCountries.map(c => (
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-white/80 text-xs font-[Inter] font-medium" style="background: rgba(86,172,224,0.08); border-color: rgba(86,172,224,0.2)">
              <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background: #56ACE0"></span>
              {c.label}
            </span>
          ))}
        </div>
      </div>

    </div>

    <!-- Stats strip -->
    <div class="animate-in-element mt-16 grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
      {[
        { value: "9", label: "Countries" },
        { value: "51,800+", label: "Children Supported" },
        { value: "3", label: "Active Crisis Zones" },
        { value: "6", label: "Partner Networks" },
      ].map(stat => (
        <div class="text-center">
          <div class="font-[Montserrat] font-bold text-white leading-none mb-1.5" style="font-size: clamp(2rem, 4vw, 2.75rem)">{stat.value}</div>
          <div class="text-[11px] font-[Inter] text-white/40 tracking-wide uppercase">{stat.label}</div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('is-visible');
    }),
    { threshold: 0.08, rootMargin: '-40px' }
  );
  document.querySelectorAll('#reach .animate-in-element').forEach(el => observer.observe(el));
</script>
