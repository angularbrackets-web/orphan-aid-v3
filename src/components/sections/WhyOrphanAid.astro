---
import { FallingPattern } from "@/components/react/FallingPattern";
import { ImageRotationCarousel } from "@/components/react/ImageRotationCarousel";

const differentiators = [
  {
    title: "Specialized Focus",
    body: "We dedicate 100% of our orphan initiative to orphan care and underserved regions — no dilution, no distraction.",
    accent: "#0d47a1",
    number: "01",
  },
  {
    title: "Scalable Systems",
    body: "We are building a structured, professional organization designed to grow sustainably with every new sponsor.",
    accent: "#FFB300",
    number: "02",
  },
  {
    title: "Accountability",
    body: "We deliver support with consistency, dignity, and rigorous financial management — every dollar tracked.",
    accent: "#0d47a1",
    number: "03",
  },
  {
    title: "Bold Vision",
    body: "A clear goal to support at least 10% of the world's orphaned children through sustainable, lasting care.",
    accent: "#FFB300",
    number: "04",
  },
];

const carouselImages = [
  { id: "img1", src: "/pexels-2xman-yef-469319062-34053480.jpg", alt: "Child supported by Orphan Aid" },
  { id: "img2", src: "/pexels-elvis-kambire-434351765-29396574.jpg", alt: "Child supported by Orphan Aid" },
  { id: "img3", src: "/pexels-halaframe-35210451.jpg", alt: "Child supported by Orphan Aid" },
  { id: "img4", src: "/pexels-nuray-yakin-644768945-17838366.jpg", alt: "Child supported by Orphan Aid" },
  { id: "img5", src: "/pexels-rcp24-35617731.jpg", alt: "Child supported by Orphan Aid" },
  { id: "img6", src: "/pexels-samimibirfotografci-319596948-15953951.jpg", alt: "Child supported by Orphan Aid" },
];
---

<section id="why" class="relative py-28 md:py-36 bg-[#f5f5f5] overflow-hidden">
  <FallingPattern
    client:visible
    color="rgba(38,50,56,0.05)"
    backgroundColor="#f5f5f5"
    duration={170}
    blurIntensity="0.8em"
    density={1}
  />

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Left: Rotating image carousel -->
      <div class="animate-in-element flex items-center justify-center order-2 lg:order-1">
        <ImageRotationCarousel client:visible images={carouselImages} />
      </div>

      <!-- Right: Content -->
      <div class="order-1 lg:order-2">

        <!-- Label -->
        <div class="animate-in-element mb-6">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#263238]/8 border border-[#263238]/15 text-[#263238]/70 text-xs font-[Montserrat] font-semibold tracking-widest uppercase">
            Why We're Different
          </span>
        </div>

        <!-- Headline -->
        <div class="animate-in-element mb-10">
          <h2 class="font-[Montserrat] font-semibold text-[#263238] leading-[1.05] tracking-[-0.02em] mb-5" style="font-size: clamp(2.4rem, 4.5vw, 3.6rem)">
            Why Our Approach<br />
            <span class="text-[#0d47a1]">Is Different</span>
          </h2>
          <p class="text-base font-[Inter] text-[#263238]/55 leading-[1.65] max-w-md">
            While many provide general relief, Orphan Aid is dedicated specifically
            to the long-term success of orphans.
          </p>
        </div>

        <!-- Numbered list -->
        <div class="divide-y divide-[#263238]/10">
          {differentiators.map((d, i) => (
            <div
              class="animate-in-element flex gap-5 py-6 group"
              style={`transition-delay: ${i * 80}ms`}
            >
              <!-- Oversized faded number -->
              <div class="flex-shrink-0 w-16">
                <span
                  class="font-[Satoshi] font-black leading-none select-none transition-opacity duration-300 group-hover:opacity-40"
                  style={`font-size: 4rem; color: ${d.accent}; opacity: 0.18; line-height: 1`}
                >
                  {d.number}
                </span>
              </div>

              <!-- Content -->
              <div class="pt-1">
                <h3
                  class="font-[Montserrat] font-bold text-[#263238] mb-2 leading-[1.15] transition-colors duration-200"
                  style="font-size: clamp(1.1rem, 2vw, 1.35rem)"
                >
                  {d.title}
                </h3>
                <p class="font-[Inter] text-[#263238]/58 leading-[1.65] text-sm">{d.body}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('is-visible');
    }),
    { threshold: 0.08, rootMargin: '-40px' }
  );
  document.querySelectorAll('#why .animate-in-element').forEach(el => observer.observe(el));
</script>
