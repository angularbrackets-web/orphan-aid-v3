---
import { FallingPattern } from "@/components/react/FallingPattern";

const tiers = [
  {
    id: "daily",
    name: "Daily Mercy",
    price: 33,
    tagline: "Daily food, basic clothing, and access to community care.",
    features: [
      "Daily nutritious meals",
      "Basic clothing & essentials",
      "Community care access",
      "Monthly impact report",
    ],
    featured: false,
  },
  {
    id: "full",
    name: "Full Sponsorship",
    price: 89,
    tagline: "Complete support including school fees, supplies, and direct guardian assistance.",
    features: [
      "Everything in Daily Mercy",
      "School fees & supplies",
      "Direct guardian assistance",
      "Quarterly personal updates",
      "Tax receipt issued",
    ],
    featured: true,
  },
  {
    id: "priority",
    name: "Priority Sponsorship",
    price: 120,
    tagline: "Emergency medical, trauma care, and food in high-cost crisis zones like Palestine.",
    features: [
      "Everything in Full Sponsorship",
      "Emergency medical care",
      "Trauma support services",
      "Crisis zone priority access",
      "Direct impact verification",
    ],
    featured: false,
  },
];
---

<section id="sponsor" class="relative py-28 md:py-36 bg-white overflow-hidden">
  <FallingPattern
    client:visible
    color="rgba(255,179,0,0.06)"
    backgroundColor="white"
    duration={140}
    blurIntensity="0.8em"
    density={1}
  />

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <!-- Label -->
    <div class="animate-in-element flex justify-center mb-8">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#FFB300]/15 border border-[#FFB300]/30 text-[#e6a100] text-xs font-[Montserrat] font-semibold tracking-widest uppercase">
        Choose Your Impact
      </span>
    </div>

    <!-- Headline -->
    <div class="animate-in-element text-center max-w-3xl mx-auto mb-6">
      <h2 class="font-[Montserrat] font-bold text-[#263238] leading-[1.05] tracking-[-0.02em]" style="font-size: clamp(2.8rem, 6vw, 4.5rem)">
        You Can Be<br />
        <span class="text-[#FFB300]">the Change</span>
      </h2>
    </div>
    <div class="animate-in-element text-center max-w-2xl mx-auto mb-20">
      <p class="text-lg font-[Inter] text-[#263238]/55 leading-[1.6]">
        Choose a monthly commitment that provides consistent stability in an orphan's life.
        Every tier makes a real, traceable difference.
      </p>
    </div>

    <!-- Tier Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-end">
      {tiers.map((tier, i) => (
        <div
          class={`animate-in-element group relative rounded-2xl overflow-hidden transition-all duration-350 hover:-translate-y-2 ${
            tier.featured
              ? 'bg-[#263238] shadow-2xl shadow-[#263238]/20 md:-translate-y-6 hover:shadow-[0_32px_64px_rgba(38,50,56,0.30)]'
              : 'bg-white shadow-[0_4px_24px_rgba(0,0,0,0.07)] hover:shadow-[0_16px_56px_rgba(0,0,0,0.13)]'
          }`}
          style={`transition-delay: ${i * 120}ms`}
        >
          <!-- Top accent bar -->
          <div class={`h-1 group-hover:h-[5px] w-full transition-all duration-300 ${tier.featured ? 'bg-[#FFB300]' : 'bg-[#0d47a1]/20 group-hover:bg-[#0d47a1]/40'}`}></div>

          {tier.featured && (
            <div class="absolute top-5 right-5 z-10">
              <span class="px-3 py-1 rounded-full bg-[#FFB300] text-[#263238] text-[10px] font-[Montserrat] font-black tracking-widest uppercase shadow-md">
                Most Popular
              </span>
            </div>
          )}

          <div class="p-8">
            <!-- Tier name -->
            <div class={`text-[10px] font-[Montserrat] font-bold tracking-widest uppercase mb-4 ${tier.featured ? 'text-white/50' : 'text-[#263238]/40'}`}>
              {tier.name}
            </div>

            <!-- Price -->
            <div class="flex items-end gap-0.5 mb-2">
              <span class={`text-2xl font-[Montserrat] font-medium leading-none mb-1 ${tier.featured ? 'text-[#FFB300]/70' : 'text-[#263238]/50'}`}>$</span>
              <span class={`font-[Montserrat] font-bold leading-none ${tier.featured ? 'text-[#FFB300]' : 'text-[#263238]'}`} style="font-size: clamp(3rem, 5vw, 3.75rem)">{tier.price}</span>
              <span class={`text-sm font-[Inter] font-medium mb-1.5 ml-0.5 ${tier.featured ? 'text-white/40' : 'text-[#263238]/40'}`}>/mo</span>
            </div>
            <p class={`text-sm font-[Inter] leading-[1.6] mb-8 ${tier.featured ? 'text-white/60' : 'text-[#263238]/55'}`}>{tier.tagline}</p>

            <!-- Features -->
            <ul class="space-y-3 mb-8">
              {tier.features.map((f) => (
                <li class="flex items-start gap-3">
                  <div class={`shrink-0 mt-0.5 w-5 h-5 rounded-full flex items-center justify-center ${tier.featured ? 'bg-[#FFB300]/15' : 'bg-[#0d47a1]/8'}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke={tier.featured ? '#FFB300' : '#0d47a1'} stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </div>
                  <span class={`text-sm font-[Inter] font-medium ${tier.featured ? 'text-white/75' : 'text-[#263238]/70'}`}>{f}</span>
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href="#"
              class={`block w-full text-center py-4 rounded-xl text-sm font-[Montserrat] font-bold tracking-wide transition-all duration-200 hover:scale-[1.02] active:scale-[0.98] ${
                tier.featured
                  ? 'bg-[#FFB300] text-[#263238] hover:bg-[#e6a100] shadow-md hover:shadow-lg'
                  : 'bg-[#263238] text-white hover:bg-[#37474f]'
              }`}
            >
              Sponsor Now — ${tier.price}/mo
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust note -->
    <div class="animate-in-element mt-12 text-center">
      <p class="text-sm font-[Inter] text-[#263238]/40 font-medium">
        🔒 Cancel anytime &nbsp;·&nbsp; Official tax receipts issued &nbsp;·&nbsp; 100% goes to orphan care
      </p>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('is-visible');
    }),
    { threshold: 0.08, rootMargin: '-40px' }
  );
  document.querySelectorAll('#sponsor .animate-in-element').forEach(el => observer.observe(el));
</script>
