---
---

<section id="finalcta" class="relative py-28 md:py-36 bg-[#0f172a] overflow-hidden">
  <!-- Radial glow -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 70% 60% at 50% 40%, rgba(86,172,224,0.12), transparent 70%)"></div>
  <!-- Subtle bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-48 pointer-events-none" style="background: linear-gradient(to top, rgba(15,23,42,0.6), transparent)"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <div class="animate-in-element">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/50 text-xs font-semibold tracking-widest uppercase mb-8">
        Take Action Today
      </div>

      <!-- Headline -->
      <h2 class="text-5xl sm:text-6xl md:text-7xl font-[Satoshi] font-semibold text-white leading-[1.05] tracking-[-0.02em] mb-8">
        No Child Should Be<br />
        <span class="relative inline-block text-[#FFB300]">
          Left Behind
          <svg class="absolute -bottom-3 left-0 w-full" height="8" viewBox="0 0 300 8" fill="none" preserveAspectRatio="none" aria-hidden="true">
            <path d="M0 7 Q75 1 150 5 Q225 9 300 3" stroke="#FFB300" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.5"/>
          </svg>
        </span>
      </h2>

      <!-- Sub-headline -->
      <p class="text-xl md:text-2xl text-white/60 font-medium leading-[1.6] max-w-2xl mx-auto mb-12">
        Your support provides the care, stability, and opportunity every child deserves.
        Join our global effort to reach the children who need it most.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-14">
        <a
          href="#sponsor"
          class="inline-flex items-center justify-center px-10 py-5 rounded-full text-lg font-semibold bg-[#FFB300] text-[#263238] hover:bg-[#e6a100] transition-all duration-200 shadow-xl hover:shadow-2xl hover:-translate-y-1"
        >
          Sponsor an Orphan Now
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="#mission"
          class="inline-flex items-center justify-center px-10 py-5 rounded-full text-lg font-bold text-white border-2 border-white/20 hover:bg-white/8 transition-all duration-200"
        >
          Learn More
        </a>
      </div>

      <!-- Trust badges -->
      <div class="flex flex-wrap items-center justify-center gap-6 text-sm font-semibold text-white/35">
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Registered Canadian Charity
        </span>
        <span class="w-1 h-1 rounded-full bg-white/20 hidden sm:block"></span>
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Tax Receipts Issued
        </span>
        <span class="w-1 h-1 rounded-full bg-white/20 hidden sm:block"></span>
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Cancel Anytime
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('is-visible');
    }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('#finalcta .animate-in-element').forEach(el => observer.observe(el));
</script>
